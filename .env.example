# Database (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./cvi.db

# Authentik OIDC — ganti dengan URL issuer Authentik Anda
# Format: https://<authentik-domain>/application/o/<application-slug>/
AUTHENTIK_ISSUER_URL=https://authentik.example.com/application/o/cvi/

# Nama grup Authentik yang dipetakan ke role
AUTHENTIK_ADMIN_GROUP=cvi-admin
AUTHENTIK_EXPERT_GROUP=cvi-expert

# Aplikasi
APP_ENV=development

# CORS — daftar origin yang diizinkan (JSON array sebagai string)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
